# Root environment file for zero-sum.
# Copy to .env and edit as needed.

# ── OpenAI (optional) ───────────────────────────────────
# Required only for AI-generated stock/news analysis.
OPENAI_API_KEY=
OPENAI_ORG_ID=
ANALYSIS_MODEL=gpt-4o
ANALYSIS_CACHE_HOURS=24

# U.S. congress trading data (Quiver Quant API).
# Taiwan-focused deployments can keep this OFF.
ENABLE_CONGRESS_TRADES=0

# yfinance download stability tuning.
YF_DOWNLOAD_THREADS=3
YF_DOWNLOAD_RETRIES=2
YF_DOWNLOAD_TIMEOUT_SEC=20
